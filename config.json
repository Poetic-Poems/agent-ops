{
  "repos": [
    {
      "slug": "Poetic-Poems/poetic",
      "sources": ["security", "review-feedback", "failed-runs", "tech-debt", "issues", "project-review", "code-quality"]
    },
    {
      "slug": "Poetic-Poems/poetic-fiddle",
      "sources": ["security", "review-feedback", "failed-runs", "tech-debt", "issues", "implementation-plan", "project-review", "code-quality"]
    }
  ],
  "state_dir": "~/.local/state/poetic-agents",
  "workspace_root": "~/.cache/poetic-agents/workspaces",
  "state_repo": "Poetic-Poems/agent-ops-state",
  "cycles_retained": 200,
  "state_local_cycles_retained": 1000,
  "coordinator_model": "claude-haiku-4-5-20251001",
  "implementor_model_default": "claude-sonnet-5",
  "implementor_model_trivial": "claude-haiku-4-5-20251001",
  "reviewer_model": "claude-sonnet-5",
  "pr_label": "autonomous-agent",
  "branch_prefix": "agent/",
  "max_open_agent_prs": 3,
  "candidates_max": 3,
  "claim_ttl_hours": 6,
  "timeout_coordinator": 15,
  "timeout_implementor": 90,
  "timeout_reviewer": 30,
  "lock_stale_after": 3,
  "limit_cooldown_default": 3,
  "disable_default_ttl": 4,
  "none_selected_recheck_hours": 24,
  "dashboard_refresh_seconds": 5,
  "review": {
    "repos": ["Poetic-Poems/poetic", "Poetic-Poems/poetic-fiddle"],
    "model": "claude-sonnet-5",
    "pr_label": "project-review",
    "branch_prefix": "review/",
    "timeout_review": 120,
    "lock_stale_after": 6,
    "min_days_between_reviews": 6
  }
}
