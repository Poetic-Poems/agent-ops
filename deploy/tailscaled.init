#!/bin/sh
### BEGIN INIT INFO
# Provides:          tailscaled
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Tailscale node agent (private tailnet access to the dashboard)
### END INIT INFO
#
# Install: see the "View it away from home (Tailscale)" section of README.md.
# In short —
#   sudo install -m 755 deploy/tailscaled.init /etc/init.d/tailscaled
#   sudo service tailscaled start
# and add it to /etc/wsl.conf's [boot] command, alongside cron.
#
# Runs tailscaled so `tailscale serve` can proxy the dashboard's
# loopback-only server (127.0.0.1:8787) over the owner's private tailnet.
# Unlike agent-ops-dashboard.init this runs as root deliberately: tailscaled
# needs root to open /dev/net/tun and to manage its state under
# /var/lib/tailscale. The dashboard server itself stays unprivileged and
# loopback-only; nothing here opens a public port or URL.

NAME=tailscaled
DAEMON=/usr/sbin/tailscaled
PIDFILE=/var/run/$NAME.pid
LOGFILE=/var/log/tailscaled.log
STATEDIR=/var/lib/tailscale
SOCKET=/run/tailscale/tailscaled.sock
CMD="exec $DAEMON --state=$STATEDIR/tailscaled.state --socket=$SOCKET --port=41641 >>$LOGFILE 2>&1"

case "$1" in
  start)
    if [ ! -x "$DAEMON" ]; then
      echo "$NAME: $DAEMON not found — install Tailscale first (see README)" >&2
      exit 1
    fi
    # Same duplicate-start guard as agent-ops-dashboard.init: the tracked
    # process execs from /bin/bash into tailscaled, so start-stop-daemon
    # can't match it by --exec; check the pidfile explicitly instead.
    if [ -f "$PIDFILE" ]; then
      OLDPID=$(cat "$PIDFILE" 2>/dev/null)
      if [ -n "$OLDPID" ] && kill -0 "$OLDPID" 2>/dev/null; then
        echo "$NAME is already running (pid $OLDPID)"
        exit 0
      fi
      echo "Removing stale pidfile for $NAME"
      rm -f "$PIDFILE"
    fi
    mkdir -p "$STATEDIR" "$(dirname "$SOCKET")"
    echo "Starting $NAME"
    start-stop-daemon --start --background --make-pidfile --pidfile "$PIDFILE" \
      --exec /bin/bash -- -c "$CMD"
    ;;
  stop)
    echo "Stopping $NAME"
    start-stop-daemon --stop --pidfile "$PIDFILE" --retry TERM/10/KILL/5
    rm -f "$PIDFILE"
    ;;
  restart)
    "$0" stop
    sleep 1
    "$0" start
    ;;
  status)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "$NAME is running (pid $(cat "$PIDFILE"))"
    else
      echo "$NAME is not running"
      exit 1
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
