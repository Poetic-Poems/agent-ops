# deploy/docker/.env.example — copy to .env beside compose.yaml and fill in.
#
#   cp .env.example .env && $EDITOR .env
#
# .env is git-ignored and holds this node's secrets. It is the only file that
# differs between nodes; everything else comes from the image. Nothing here is
# ever committed — if a token ends up in a commit, rotate it rather than
# rewriting history.

# --- Identity -----------------------------------------------------------
# The node's name, used as its Tailscale hostname and stamped into its logs.
# Give each node a name you would recognise in a list at 3am.
NODE_NAME=

# active | standby. Exactly one node in the operation may be active: it is the
# one that runs cycles and opens pull requests. Every other node keeps its
# schedule and stands each cycle down (see AGENT_OPS_ROLE in the specs).
# Anything that is not exactly "active" means standby, including a typo.
ROLE=standby

# --- Which services this node runs ---------------------------------------
# tailnet | local, plus auto-update. See the header of compose.yaml.
# Use "local,auto-update" on a machine with no tailnet or no authkey.
COMPOSE_PROFILES=tailnet,auto-update

# --- GitHub --------------------------------------------------------------
# A token with the scopes the cycles need: read and write on the target
# repositories (contents, pull requests, issues), read on their alerts, and
# read/write on the private state repository named by `state_repo` in
# config.json — every node reads it to stay warm, and the active node writes
# its state and the lease there.
# Prefer a fine-grained token, scoped to the Poetic-Poems repositories, with an
# expiry — and a separate one per node, so a single node can be revoked.
GH_TOKEN=

# The identity the agents' commits carry. Both default inside the image; set
# them here only to override.
#GIT_USER_NAME=
#GIT_USER_EMAIL=

# --- Tailscale (tailnet profile) -----------------------------------------
# A pre-authentication key from the tailnet's admin console. Use a reusable,
# ephemeral-off, pre-approved key if you are provisioning several nodes; it is
# consumed once at first start and the node's identity then lives in the
# tailscale-state volume.
TS_AUTHKEY=

# --- Optional ------------------------------------------------------------
# The image to run. Override to test a locally built image (AGENT_OPS_IMAGE=agent-ops)
# or to pin a node to a known-good build by digest or SHA tag.
#AGENT_OPS_IMAGE=ghcr.io/poetic-poems/agent-ops:latest

# The container's timezone. Affects the cron schedule, so a node in another
# region still runs its cycles on the hours the operation expects.
#TZ=Pacific/Auckland

# The host port for the local profile.
#DASHBOARD_PORT=8787

# The scheduler's network MTU. Set this to the host's egress MTU whenever that
# is below 1500 — behind WireGuard or Tailscale, on some cloud instances, and
# in WSL. Symptom of getting it wrong: DNS and plain HTTP work inside the
# container while every TLS connection hangs and resets, so `gh`, `claude` and
# `git clone` all fail as though the token were bad. Find it with:
#   ip route get 1.1.1.1        # names the egress interface
#   ip link show <interface>    # gives its mtu
#DOCKER_MTU=1500

# How often watchtower looks for a new image, in seconds.
#WATCHTOWER_POLL_INTERVAL=300
